# ── Copy this file to .env and fill in your values ──────────────────────────
# cp .env.example .env

# GitHub token with "Contents: Read & Write" scope
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Target GitHub repository ("owner/repo-name")
GH_REPO=Tagoletta/Fed0gaT

# Subdirectory inside the repo where feed files live
DATA_DIR=feeds

# Web dashboard secret key (generate with: openssl rand -hex 32)
WEB_SECRET=change-me-to-a-long-random-string

# Git committer identity (for scraper commits)
GIT_NAME=Fed0gaT Bot
GIT_EMAIL=bot@fed0gat.local

# Web dashboard port on the host
WEB_PORT=5000

# Set to 1 to test the scraper without pushing to GitHub
DRY_RUN=0
